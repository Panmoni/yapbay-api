{
  "name": "yapbay-api",
  "version": "0.2.1",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "bash scripts/install-hooks.sh",
    "test": "mocha",
    "test:property": "mocha --no-config -r ts-node/register 'src/tests/**/*.property.test.ts'",
    "test:contract": "mocha --no-config -r ts-node/register 'src/tests/**/*.contract.test.ts'",
    "test:integration": "mocha --config .mocharc.integration.json",
    "test:blockchain": "mocha -r ts-node/register 'src/tests/blockchain.test.ts'",
    "test:deadline": "ts-node scripts/test-deadline.ts",
    "test:connection": "ts-node scripts/test-connection.ts",
    "test:escrow-monitoring": "ts-node scripts/test-escrow-monitoring.ts",
    "start": "ts-node src/server.ts",
    "start:events": "ts-node scripts/start-event-listener.ts",
    "start:dev": "nodemon --exec 'ts-node --project tsconfig.json --files' src/server.ts",
    "build": "tsc",
    "serve": "node dist/server.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:shell": "bash scripts/lint-shell.sh",
    "check:coercion": "bash scripts/check-amount-coercion.sh",
    "hooks:install": "bash scripts/install-hooks.sh",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test-events": "ts-node scripts/test-events.ts",
    "list-active-trades": "ts-node scripts/list-active-trades.ts",
    "build-image": "podman build -f Containerfile -t localhost/yapbay-api:latest .",
    "deploy": "pnpm build && pnpm build-image && systemctl --user stop yapbay-api.service && systemctl --user start yapbay-api.service",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "logs": "journalctl --user -u yapbay-api.service -f",
    "start:service": "systemctl --user start yapbay-api.service",
    "stop": "systemctl --user stop yapbay-api.service",
    "restart": "systemctl --user stop yapbay-api.service && systemctl --user start yapbay-api.service",
    "status": "systemctl --user status yapbay-api.service --no-pager",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "migrate:backup": "node scripts/migrate.js --backup-only",
    "migrate:dry-run": "node scripts/migrate.js --dry-run",
    "migrate:verify": "node scripts/migrate.js --verify-only",
    "migrate:rollback": "node scripts/migrate.js --rollback",
    "migrate:health": "node scripts/db/migration-health-check.js",
    "db:health": "node scripts/db/db-health-check.js",
    "db:health:verbose": "node scripts/db/db-health-check.js --verbose",
    "deploy:check": "node scripts/db/deployment-gate.js"
  },
  "author": "",
  "license": "MIT",
  "description": "API for YapBay Escrow on Celo Alfajores testnet",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bcrypt": "^5.0.0",
    "@types/chai": "^4.3.19",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.11.12",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "chai": "^4.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "fast-check": "^4.6.0",
    "lint-staged": "^16.4.0",
    "mocha": "^11.1.0",
    "nodemon": "^3.1.9",
    "semantic-release": "25.0.3",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "ultracite": "^7.4.3"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@coral-xyz/anchor": "^0.30.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.98.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "opossum": "^9.0.0",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "diff": "8.0.3",
      "serialize-javascript": "7.0.5",
      "follow-redirects": ">=1.16.0",
      "protobufjs": ">=7.5.5",
      "uuid": ">=14.0.0"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "biome format --write",
      "biome check --write"
    ],
    "*.{json,jsonc,md}": [
      "biome format --write"
    ]
  }
}
