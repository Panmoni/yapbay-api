# =============================================================================
# YapBay API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
POSTGRES_URL=postgres://yapbay:PASSWORD@127.0.0.1:5432/yapbay

# Server port (default: 3000)
PORT=3011

# Environment: development | production
NODE_ENV=development

# Contract version identifier
CONTRACT_VERSION=0.1.2

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# [REQUIRED] JWT signing secret (base64-encoded, 64+ bytes recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=

# JWT audience claim validation (optional)
# JWT_AUDIENCE=

# Dynamic SDK application ID for JWKS verification
DYNAMIC_ID=

# Admin credentials
ADMIN_USERNAME=
# Generate hash: node -e "console.log(require('bcrypt').hashSync('YOUR_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------

SOLANA_PROGRAM_ID_DEVNET=
SOLANA_PROGRAM_ID_MAINNET=
SOLANA_USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

SOLANA_ARBITRATOR_ADDRESS=
# JSON array of keypair bytes
SOLANA_ARBITRATOR_KEYPAIR=

# Helius or other Solana RPC endpoint (contains API key — never log directly)
SOLANA_RPC_URL_DEVNET=

SOLANA_BUYER_ADDRESS=
SOLANA_SELLER_ADDRESS=

# -----------------------------------------------------------------------------
# Celo (currently disabled, preserved for future re-enablement)
# -----------------------------------------------------------------------------

# CELO_RPC_URL_TESTNET=https://alfajores-forno.celo-testnet.org
# CELO_WS_URL_TESTNET=wss://alfajores-forno.celo-testnet.org/ws
# CELO_RPC_URL=https://forno.celo.org
# CELO_WS_URL=https://forno.celo.org/ws
# CELO_CONTRACT_ADDRESS_TESTNET=
# CELO_CONTRACT_ADDRESS=
# CELO_ARBITRATOR_ADDRESS=
# CELO_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated allowed origins (used in production/staging)
# If not set, defaults to https://app.yapbay.com in production
# CORS_ORIGINS=https://app.yapbay.com

# Legacy single-origin vars (used if CORS_ORIGINS is not set)
CORS_ORIGIN_PROD=https://app.yapbay.com
CORS_ORIGIN_DEV=http://localhost:5173

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

PRICING_SERVER_URL=http://localhost:4000

# Event listener starting blocks
FROM_BLOCK_MAINNET=
FROM_BLOCK_TESTNET=

# -----------------------------------------------------------------------------
# Schedulers
# -----------------------------------------------------------------------------

# Auto-cancel expired trades (cron expression, default: every minute)
DEADLINE_CRON_SCHEDULE=*/1 * * * *

# Escrow monitoring
ESCROW_MONITOR_ENABLED=true
ESCROW_MONITOR_CRON_SCHEDULE=* * * * *
ESCROW_MONITOR_BATCH_SIZE=50
AUTO_CANCEL_DELAY_HOURS=1

# -----------------------------------------------------------------------------
# Security Middleware
# -----------------------------------------------------------------------------

# Number of proxy hops to trust for X-Forwarded-* headers (default: 1)
# Set to match your infrastructure (e.g., 1 for single reverse proxy)
TRUST_PROXY_HOPS=1

# Request timeout in milliseconds (default: 35000 = 35 seconds)
EXPRESS_REQUEST_TIMEOUT_MS=35000

# Enforce HTTPS in production (default: true unless explicitly "false")
# Set to "false" only for local development or if TLS terminates upstream
# ENFORCE_HTTPS=true

# HSTS (HTTP Strict Transport Security) — only active in production
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=false
# HSTS_PRELOAD=false

# -----------------------------------------------------------------------------
# Cloudflare Integration (all optional, feature-flagged)
# -----------------------------------------------------------------------------

# Set to "true" to enable automatic IP banning via Cloudflare API.
# When false (default), suspicious patterns are detected and rate-limited
# but no Cloudflare API calls are made and no ban DB queries run.
CF_BAN_ENABLED=false

# [REQUIRED if CF_BAN_ENABLED=true] Cloudflare API bearer token
# CF_API_TOKEN=

# [REQUIRED if CF_BAN_ENABLED=true] Cloudflare zone ID
# CF_ZONE_ID=

# Set to "true" if running behind Cloudflare (trusts CF-Connecting-IP header)
CF_BEHIND=false

# Comma-separated IPs exempt from suspicious pattern detection and rate limiting
# (e.g., your own monitoring, CI/CD, or server IPs)
# CF_TRUSTED_IPS=

# Ban duration in days (default: 180)
# CF_BAN_EXPIRY_DAYS=180

# Number of IPs from the same /24 subnet that triggers automatic subnet ban (default: 2)
# CF_SUBNET_ESCALATION_THRESHOLD=2

# ---- Database connection pool tuning ----
# Max and min connections held by the app pool.
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# How long an idle client sits in the pool before it's released (ms).
# DB_POOL_IDLE_TIMEOUT_MS=30000
# How long pool.connect() waits for a free client before throwing (ms).
# DB_POOL_CONNECTION_TIMEOUT_MS=10000
# Server-side statement_timeout — PG aborts any single query that runs longer.
# DB_STATEMENT_TIMEOUT_MS=30000
# Client-side query_timeout — node-postgres gives up waiting for a result.
# DB_QUERY_TIMEOUT_MS=30000

# ---- Logging ----
# Pino level: trace|debug|info|warn|error|fatal|silent (default: info; forced silent in tests).
# LOG_LEVEL=info
# Set to "true" to include request bodies in request logs (DEV ONLY — never in prod).
# LOG_BODY=false

# ---- Test safeguards ----
# Set to "1" to bypass the _test DB suffix check in src/tests/setup.ts (discouraged).
# YAPBAY_TEST_DB_OVERRIDE=
# Comma-separated list of hostnames the test guard must refuse (e.g. "db.prod.example.com").
# YAPBAY_PROD_DB_HOSTS=

# ---- Observability ----
# OpenTelemetry collector endpoint. Unset = tracing disabled (zero overhead).
# Must be https:// in production. The SDK appends /v1/traces for OTLP/HTTP.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# Service name reported on every span.
# OTEL_SERVICE_NAME=yapbay-api

# ---- Metrics ----
# Bearer token required to scrape GET /metrics in production. Required in
# production: if unset, /metrics returns 503 (fail closed).
# METRICS_AUTH_TOKEN=

# ---- Graceful shutdown ----
# Max milliseconds to drain in-flight requests on SIGTERM/SIGINT before
# stopping cron jobs, listeners, and closing the DB pool.
# SHUTDOWN_TIMEOUT_MS=30000

# ---- Reconciliation (escrow balance drift detection) ----
# Set to "false" to disable the daily reconciliation cron entirely.
# RECONCILE_ENABLED=true
# Cron schedule for the reconciliation job. Default: daily 04:00 UTC.
# RECONCILE_CRON_SCHEDULE=0 4 * * *
# Webhook URL POSTed when mismatches are found (http/https; https required
# in production). Body is JSON; signed with HMAC-SHA256 in X-YapBay-Signature
# when RECONCILIATION_WEBHOOK_SECRET is set.
# RECONCILIATION_WEBHOOK=
# Shared secret for HMAC-signing the webhook body. Strongly recommended.
# RECONCILIATION_WEBHOOK_SECRET=
# Webhook request timeout in milliseconds.
# RECONCILIATION_WEBHOOK_TIMEOUT_MS=5000
# Tolerance in basis points of the stored balance (1 bps = 0.01%). A floor
# of 0.01 USDC (10_000 micro-units) applies regardless.
# RECONCILIATION_TOLERANCE_BPS=10
# Parallel on-chain fetches per batch.
# RECONCILIATION_CONCURRENCY=25
# Safety cap: if the active escrow set exceeds this count, the job logs a
# warning and truncates. Investigate why the active set is so large.
# RECONCILIATION_ROW_LIMIT=10000
